{
  "name": "zac",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "lint": "pnpm -r lint",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "build": "pnpm -r build",
    "e2e:web": "playwright test",
    "e2e:web:ui": "playwright test --ui",
    "dev:api": "pnpm --filter @zac/api dev",
    "media:cleanup": "pnpm --filter @zac/api media:cleanup",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:apply:remote": "node --env-file=.env.local scripts/apply-sql-files.mjs infra/migrations/0002_add_operational_tables.sql infra/migrations/0003_integrate_official_source_data.sql infra/migrations/0004_event_source_accounts.sql infra/migrations/0005_add_gym_disciplines_text.sql infra/migrations/0006_source_post_observations.sql",
    "db:seed:remote": "node --env-file=.env.local scripts/apply-sql-files.mjs infra/seeds/0000_mvp_master_data.sql infra/seeds/0001_kanto_gym_directory.sql infra/seeds/0002_kanto_event_directory.sql infra/seeds/0003_comp_bible_event_sources.sql infra/seeds/generated_comp_bible_following_instagram_sources.sql infra/seeds/0004_gym_instagram_event_sources.sql infra/seeds/0005_verified_instagram_sources.sql infra/seeds/0006_verified_basecamp_expansion.sql infra/seeds/0007_noborock_calendar_refresh.sql infra/seeds/0008_event_taxonomy_refinement.sql infra/seeds/0009_noborock_route_set_backfill.sql infra/seeds/0010_official_discipline_refinement.sql infra/seeds/0011_official_discipline_and_route_set_expansion.sql infra/seeds/0012_basecamp_spider_discipline_and_kinshicho_route_set.sql infra/seeds/0013_official_discipline_bulk_sync.sql infra/seeds/0014_official_bouldering_batch_sync.sql infra/seeds/0015_official_bouldering_batch_sync.sql infra/seeds/0016_official_bouldering_batch_sync.sql infra/seeds/0017_official_bouldering_batch_sync.sql infra/seeds/0018_official_discipline_and_source_sync.sql infra/seeds/0019_bpump_ogikubo_route_set_refresh.sql infra/seeds/0020_closure_queue_official_active_sync.sql infra/seeds/0021_closure_queue_official_active_sync.sql infra/seeds/0022_closure_queue_official_active_sync.sql infra/seeds/0023_closure_queue_official_active_sync.sql infra/seeds/0024_closure_queue_official_active_sync.sql infra/seeds/0025_instagram_post_observations.sql infra/seeds/0026_verified_instagram_gym_link_backfill.sql infra/seeds/0027_instagram_candidate_queue_resolution.sql infra/seeds/0028_instagram_remaining_candidate_resolution.sql",
    "db:verify:remote": "node --env-file=.env.local scripts/verify-db-data.mjs",
    "sources:match-instagram": "node --env-file=.env.local scripts/match-instagram-sources.mjs",
    "sources:inspect-instagram": "node --env-file=.env.local scripts/inspect-instagram-post-queue.mjs",
    "sources:promote-observations": "node --env-file=.env.local scripts/promote-source-observations.mjs",
    "sources:monitor": "node --env-file=.env.local scripts/run-source-monitor.mjs",
    "sources:plan-refresh": "node --env-file=.env.local scripts/plan-source-refresh.mjs",
    "sources:automation-run": "node --env-file=.env.local scripts/run-source-automation.mjs",
    "sources:automation-local": "node --env-file=.env.local scripts/run-source-automation-local.mjs",
    "sources:automation-health": "node scripts/check-source-automation-health.mjs",
    "sources:automation-readiness": "node scripts/check-source-automation-readiness.mjs",
    "openapi:generate": "node scripts/openapi-generate.mjs",
    "openapi:check": "node scripts/openapi-check.mjs",
    "config:audit": "node scripts/config-audit.mjs",
    "secret:scan": "node scripts/secret-scan.mjs",
    "vercel:prebuild:api": "node scripts/vercel-api-prebuild.mjs",
    "vercel:deploy:api": "node scripts/vercel-api-prebuild.mjs --deploy",
    "vercel:deploy:web": "node scripts/vercel-next-prebuilt-deploy.mjs web",
    "vercel:deploy:admin": "node scripts/vercel-next-prebuilt-deploy.mjs admin",
    "check": "pnpm lint && pnpm typecheck && pnpm test && pnpm openapi:check && pnpm config:audit && pnpm build && pnpm secret:scan"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "^22.0.0",
    "drizzle-kit": "^0.31.0",
    "esbuild": "^0.28.0",
    "typescript": "^5.8.0"
  }
}
