{
  "name": "@zac/api",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "pnpm build && node dist/index.js",
    "media:cleanup": "pnpm build && node dist/jobs/media-cleanup.js",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "test": "NODE_ENV=test pnpm --filter @zac/shared build && pnpm --filter @zac/db build && pnpm build && NODE_ENV=test node --test dist/**/*.test.js",
    "build": "pnpm --filter @zac/db build && tsc -p tsconfig.json",
    "openapi:generate": "echo 'OpenAPI generation will be added with @hono/zod-openapi routes.'"
  },
  "dependencies": {
    "@hono/node-server": "^1.14.0",
    "@hono/zod-openapi": "^0.19.0",
    "@sentry/node": "^10.50.0",
    "@supabase/supabase-js": "^2.105.0",
    "@zac/db": "workspace:*",
    "@zac/shared": "workspace:*",
    "hono": "^4.7.0",
    "posthog-node": "^5.30.6",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "typescript": "^5.8.0"
  }
}
